---
import { Icon } from '@astrojs/starlight/components';
import type { StarlightIcon } from '@astrojs/starlight/types';

interface Props {
    icon?: StarlightIcon;
    title: string;
    variant: "primary" | "secondary";
}

const { icon, title, variant, ...attributes } = Astro.props;
---

<a class:list={["index-card-link", "sl-flex", variant]} {...attributes}>
        <p class="title sl-flex">
            {icon && <Icon name={icon} class="icon" size="1.333em" />}
            <span set:html={title} />
        </p>
    <div class="body"><slot /></div>
</a>

<style>
    @layer starlight.components {
        .index-card-link {
            --sl-card-border: var(--sl-color-purple);
            --sl-card-bg: var(--sl-color-purple-low);
            width: 100%;
            border: 1px solid var(--sl-color-gray-5);
            background-color: var(--sl-color-black);
            padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
            flex-direction: column;
            gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
            color: var(--sl-color-gray-3);
        }

        .index-card-link.primary {
            --sl-card-border: var(--sl-color-orange);
            --sl-card-bg: var(--sl-color-orange-low);
        }

        .index-card-link:nth-child(4n + 1) {
            --sl-card-border: var(--sl-color-orange);
            --sl-card-bg: var(--sl-color-orange-low);
        }
        .index-card-link:nth-child(4n + 3) {
            --sl-card-border: var(--sl-color-green);
            --sl-card-bg: var(--sl-color-green-low);
        }
        .index-card-link:nth-child(4n + 4) {
            --sl-card-border: var(--sl-color-red);
            --sl-card-bg: var(--sl-color-red-low);
        }
        .index-card-link:nth-child(4n + 5) {
            --sl-card-border: var(--sl-color-blue);
            --sl-card-bg: var(--sl-color-blue-low);
        }
        .title {
            font-weight: 600;
            font-size: var(--sl-text-h4);
            color: var(--sl-color-white);
            line-height: var(--sl-line-height-headings);
            gap: 1rem;
            align-items: center;
        }
        .index-card-link .icon {
            border: 1px solid var(--sl-card-border);
            background-color: var(--sl-card-bg);
            padding: 0.2em;
            border-radius: 0.25rem;
            flex-shrink: 0;
        }
        .index-card-link .body {
            margin: 0;
            font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
        }

        a {
            text-decoration: none;
            line-height: var(--sl-line-height-headings);
        }

        .icon {
            color: var(--sl-color-gray-3);
        }

        .index-card-link:hover {
            background: var(--sl-color-gray-7, var(--sl-color-gray-6));
            border-color: var(--sl-color-gray-2);
        }

        .index-card-link:hover .icon {
            color: var(--sl-color-white);
        }
    }
</style>