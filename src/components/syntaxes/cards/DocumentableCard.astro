---
import { DocumentableType, type Documentation } from "../documentation";
import DocumentationCard from "./DocumentationCard.astro";
import EventCard from "./EventCard.astro";
import ExperimentCard from "./ExperimentCard.astro";
import ExpressionCard from "./ExpressionCard.astro";
import FunctionCard from "./FunctionCard.astro";
import PropertyCard from "./PropertyCard.astro";
import TypeCard from "./TypeCard.astro";
import StructureCard from "./StructureCard.astro";
import SyntaxCard from "./SyntaxCard.astro";

export interface DocumentableCardProps {
    currentVersion: string,
    hide?: boolean,
}

interface Props {
    defaultProps: DocumentableCardProps,
    documentation: Documentation,
}

const { defaultProps, documentation }: Props = Astro.props;
---

{(() => {
    switch (documentation.type) {
        case DocumentableType.SECTION:
        case DocumentableType.EFFECT:
        case DocumentableType.CONDITION:
            return (<SyntaxCard defaultProps={defaultProps} syntax={documentation as any}/>);
        case DocumentableType.STRUCTURE:
            return (<StructureCard defaultProps={defaultProps} structure={documentation as any}/>);
        case DocumentableType.EXPRESSION:
            return (<ExpressionCard defaultProps={defaultProps} expression={documentation as any}/>);
        case DocumentableType.EVENT:
            return (<EventCard defaultProps={defaultProps} event={documentation as any}/>);
        case DocumentableType.TYPE:
            return (<TypeCard defaultProps={defaultProps} type={documentation as any}/>);
        case DocumentableType.PROPERTY:
            return (<PropertyCard defaultProps={defaultProps} property={documentation as any}/>);
        case DocumentableType.FUNCTION:
            return (<FunctionCard defaultProps={defaultProps} func={documentation as any}/>);
        case DocumentableType.EXPERIMENT:
            return (<ExperimentCard defaultProps={defaultProps} experiment={documentation as any}/>);
        default:
            return (<DocumentationCard defaultProps={defaultProps} documentation={documentation}/>);
    }
})()}
