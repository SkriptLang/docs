---
import { getCollection } from "astro:content";
import DocumentableCard from "./DocumentableCard.astro";
import { DocumentableType } from "../documentation";

interface Props {
    type: DocumentableType,
    id: string,
}

const { type, id }: Props = Astro.props;

const syntaxesCollection = await getCollection("syntaxes");
const rawSyntaxes = syntaxesCollection.find(syntax => syntax.id === 'syntaxes')!.data;
const syntax = rawSyntaxes[type.toLowerCase() + "s"][id];
(syntax as any).type = type;

let currentVersion = rawSyntaxes.source.version.split("-")[0];
if (currentVersion.endsWith(".0")) {
    currentVersion = currentVersion.slice(0, -2);
}
---

<DocumentableCard documentation={syntax} currentVersion={currentVersion} />
