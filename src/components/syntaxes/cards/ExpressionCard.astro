---
import { type Expression } from '../documentation'
import SyntaxCard from "./SyntaxCard.astro";
import SyntaxBadge from "../SyntaxBadge.astro";
import type {DocumentableCardProps} from "./DocumentableCard.astro";

interface Props {
    defaultProps: DocumentableCardProps,
    expression: Expression,
}

const { defaultProps, expression }: Props = Astro.props;
---

<SyntaxCard defaultProps={defaultProps} syntax={expression}
            data-syntax-returns={expression.returnType.name}
>
    <Fragment slot="badges">
        <SyntaxBadge
                badgeProps={{text: "Return Type", size: 'medium'}}
                entries={[{text: expression.returnType.name, cardRef: expression.returnType.id}]}
                description="The type of the value returned by this expression."
        />
    </Fragment>
</SyntaxCard>

<style is:global>
    [data-syntax-type="Expression"] {
        /* Electric Purple */
        --custom-badge-light: #BF00FF;
        --custom-badge-dark: #4B0082;
    }
</style>
