---
import { type Property } from '../documentation'
import CodeCard from "../../CodeCard.astro";
import DocumentationCard from "./DocumentationCard.astro";
import SyntaxBadge from "../SyntaxBadge.astro";

interface Props {
    property: Property,
    currentVersion: string,
}

const { property, currentVersion }: Props = Astro.props;
---

<DocumentationCard documentation={property} currentVersion={currentVersion}>
    <Fragment slot="badges">
        <SyntaxBadge
                badgeProps={{text: "Applicable Types", size: 'medium'}}
                entries={property.types
                    .sort(((a, b) => a.name.localeCompare(b.name)))
                    .map(type => ({text: type.name, cardRef: type.id}))
                }
        />
        <SyntaxBadge
                badgeProps={{text: "Applicable Syntaxes", size: 'medium'}}
                entries={property.syntaxes
                    .sort(((a, b) => a.name.localeCompare(b.name)))
                    .map(syntax => ({text: syntax.name, cardRef: syntax.id}))
                }
        />
    </Fragment>
</DocumentationCard>

<style is:global>
    [data-syntax-type="Property"] {
        /* Pink */
        --custom-badge-light: hotpink;
        --custom-badge-dark: #8B0A50;
    }
</style>
