---
// Adapted from https://github.com/withastro/starlight/blob/main/packages/starlight/user-components/CardGrid.astro
---
<div class="card-grid"><slot /></div>

<style>
	@layer starlight.components {
		.card-grid {
			display: grid;
            flex-direction: column;
			gap: 1rem;
            margin-bottom: 4rem;
		}

		.card-grid > :global(*) {
			margin-top: 0 !important;
		}

		@media (min-width: 50rem) {
			.card-grid {
                display: flex;
                flex-direction: row;
				gap: 1.5rem;
                margin-top: -6rem;
			}
		}
	}
</style>